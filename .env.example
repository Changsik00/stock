# PostgreSQL/TimescaleDB 접속 문자열 (docker-compose.yml 기본값: 포트 5433, db/user/pw=stock)
DATABASE_URL=postgresql+asyncpg://stock:stock@localhost:5433/stock

# docker-compose의 DB 비밀번호 (DATABASE_URL과 일치시킬 것). 미설정 시 compose 기본값 stock 사용
POSTGRES_PASSWORD=stock

# KRX(한국거래소) 공식 Open API — https://openapi.krx.co.kr 에서 발급
# 발급 후 마이페이지에서 사용할 데이터셋(idx/kospi_dd_trd, idx/kosdaq_dd_trd, drv/fut_bydd_trd)에
# 대해 "API 이용 신청" 승인을 별도로 받아야 실제 호출이 됩니다.
KRX_OPENAPI_KEY=

# 키움증권 REST API — openapi.kiwoom.com 에서 서비스 신청 후 앱키/시크릿 발급
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
# 1이면 모의투자 서버(mockapi.kiwoom.com) 사용, 0/미설정이면 실전(api.kiwoom.com)
KIWOOM_MOCK=0

# 한국투자증권(KIS) REST API — apiportal.koreainvestment.com 에서 앱키/시크릿 발급
KIS_APP_KEY=
KIS_APP_SECRET=

# 한국은행 ECOS API — ecos.bok.or.kr/api 에서 인증키 신청 (무료, 신청 후 1일 내 발급)
ECOS_API_KEY=

# data.krx.co.kr 무료 회원 로그인 (증권사 계좌 아님, data.krx.co.kr에서 회원가입만 하면 됨)
# 2026-02 KRX 데이터 포털 개편 이후 pykrx(시장 수급 수집, PLAN.md Phase 1-4)가 동작하려면
# 필수. 없으면 data.krx.co.kr의 모든 통계 JSON 엔드포인트가 HTTP 400 "LOGOUT"으로 거부됨.
KRX_ID=
KRX_PW=
